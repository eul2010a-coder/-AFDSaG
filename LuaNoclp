    local targetPos = playerObj.Character.PrimaryPart.Position
    local char = player.Character
    if char and char.PrimaryPart then
        char.PrimaryPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
    end
end

local function toggleSpectate()
    spectateActive = not spectateActive

    if spectateActive then
        if freeCameraActive then
            toggleFreeCamera()
        end
        if followActive then
            toggleFollowPlayer(selectedPlayer)
        end

        if selectedPlayer and selectedPlayer.Character then
            freezePlayer()
            Camera.CameraSubject = selectedPlayer.Character
            Camera.CameraType = Enum.CameraType.Custom

            spectateConnection = RunService.Heartbeat:Connect(function()
                local char = player.Character
                if char and char.PrimaryPart and playerFrozen then
                    char.PrimaryPart.CFrame = playerOriginalCFrame
                end
                if selectedPlayer and selectedPlayer.Character then
                    Camera.CameraSubject = selectedPlayer.Character
                else
                    toggleSpectate()
                end
            end)
        else
            spectateActive = false
        end
    else
        if spectateConnection then
            spectateConnection:Disconnect()
            spectateConnection = nil
        end
        unfreezePlayer()
        Camera.CameraType = Enum.CameraType.Custom
        Camera.CameraSubject = player.Character
    end
    updateMenuPopup(selectedPlayer)
end

local function updateMenuPopup(playerObj, clickPos)
    for _, child in pairs(MenuPopupContent:GetChildren()) do
        child:Destroy()
    end

    if not playerObj then
        MenuPopup.Visible = false
        return
    end

    local pos = clickPos or Vector2.new(mouse.X, mouse.Y)
    local popupWidth = 180
    local popupHeight = 200

    local x = pos.X
    local y = pos.Y

    if x + popupWidth > ScreenGui.AbsoluteSize.X then
        x = x - popupWidth
    end
    if y + popupHeight > ScreenGui.AbsoluteSize.Y then
        y = y - popupHeight
    end

    MenuPopup.Position = UDim2.new(0, x, 0, y)
    MenuPopup.Size = UDim2.new(0, popupWidth, 0, popupHeight)
    MenuPopup.Visible = true
    MenuPopupTitleLabel.Text = playerObj.DisplayName or playerObj.Name

    local statusText = "● Idle"
    local statusColor = Color3.fromRGB(200, 200, 200)
    if spectateActive then 
        statusText = "● Spectating"
        statusColor = Color3.fromRGB(100, 255, 100)
    elseif followActive then 
        statusText = "● Following"
        statusColor = Color3.fromRGB(100, 255, 100)
    elseif freeCameraActive then 
        statusText = "● Free Camera"
        statusColor = Color3.fromRGB(100, 255, 100)
    end

    local statusLabel = Instance.new("TextLabel")
    statusLabel.Parent = MenuPopupContent
    statusLabel.Size = UDim2.new(1, -10, 0, 20)
    statusLabel.Position = UDim2.new(0, 5, 0, 5)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Text = statusText
    statusLabel.TextColor3 = statusColor
    statusLabel.TextSize = 10
    statusLabel.Font = Enum.Font.GothamMedium
    statusLabel.TextXAlignment = Enum.TextXAlignment.Left

    local actions = {
        {name = "Info", icon = "ℹ", action = function()
            showPlayerInfo(playerObj)
            MenuPopup.Visible = false
        end},
        {name = followActive and "Stop Follow" or "Follow", icon = "👁", action = function()
            toggleFollowPlayer(playerObj)
        end},
        {name = freeCameraActive and "Stop Free" or "Free Cam", icon = "🎥", action = function()
            toggleFreeCamera()
        end},
        {name = "Teleport", icon = "🚀", action = function()
            teleportToPlayer(playerObj)
            MenuPopup.Visible = false
        end},
        {name = spectateActive and "Stop Spec" or "Spectate", icon = "👀", action = function()
            toggleSpectate()
        end},
    }

    for i, action in ipairs(actions) do
        local btn = Instance.new("TextButton")
        btn.Parent = MenuPopupContent
        btn.Size = UDim2.new(1, -10, 0, 24)
        btn.Position = UDim2.new(0, 5, 0, 30 + (i-1) * 28)

        local isActive = false
        if action.name == "Stop Follow" or action.name == "Follow" then
            isActive = followActive
        elseif action.name == "Stop Free" or action.name == "Free Cam" then
            isActive = freeCameraActive
        elseif action.name == "Stop Spec" or action.name == "Spectate" then
            isActive = spectateActive
        end

        btn.BackgroundColor3 = isActive and Color3.fromRGB(60, 40, 40) or Color3.fromRGB(30, 30, 40)
