UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if MenuPopup.Visible then
            local mousePos = Vector2.new(input.Position.X, input.Position.Y)
            local popupPos = Vector2.new(MenuPopup.AbsolutePosition.X, MenuPopup.AbsolutePosition.Y)
            local popupSize = Vector2.new(MenuPopup.AbsoluteSize.X, MenuPopup.AbsoluteSize.Y)
            if not (mousePos.X >= popupPos.X and mousePos.X <= popupPos.X + popupSize.X and
                mousePos.Y >= popupPos.Y and mousePos.Y <= popupPos.Y + popupSize.Y) then
                MenuPopup.Visible = false
            end
        end
    end
end)

local dragging = false
local dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

