local function updateServerSideList()
    for _, child in pairs(ServerSideFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    local playersData = getServerPlayers()
    local count = 0
    for _ in pairs(playersData) do count = count + 1 end

    local header = Instance.new("TextLabel")
    header.Parent = ServerSideFrame
    header.Size = UDim2.new(1, 0, 0, 30)
    header.BackgroundTransparency = 1
    header.Text = "🌐 Server Players (" .. count .. ")"
    header.TextColor3 = Color3.fromRGB(200, 200, 220)
    header.TextSize = 16
    header.Font = Enum.Font.GothamBold
    header.TextXAlignment = Enum.TextXAlignment.Left

    ServerSideFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(count * 53 + 50, 400))

    local i = 1
    for id, data in pairs(playersData) do
        createServerSideEntry(id, data, i)
        i = i + 1
    end
end

