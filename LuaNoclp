-- ============ HTTP ФУНКЦИИ ============

local function httpRequest(method, url, data)
    local headers = {}
    if data then
        headers["Content-Type"] = "application/json"
    end
    
    if http and http.request then
        local response = http.request({
            Url = url,
            Method = method,
            Headers = headers,
            Data = data or ""
        })
        if response and response.StatusCode == 200 then
            return response.Body
        end
    end
    
    if request then
        local response = request({
            Url = url,
            Method = method,
            Headers = headers,
            Data = data or ""
        })
        if response and response.StatusCode == 200 then
            return response.Body
        end
    end
    
    return nil
end

-- ============ ФУНКЦИИ РАБОТЫ С СЕРВЕРОМ ============

local function registerPlayer()
    local url = SERVER_URL .. "/api/players"
    local data = {
        playerId = tostring(player.UserId),
        playerName = player.Name,
        displayName = player.DisplayName or player.Name
    }
    local jsonData = '{"playerId":"' .. data.playerId .. '","playerName":"' .. data.playerName .. '","displayName":"' .. data.displayName .. '"}'
    
    print("📡 Регистрация...")
    local response = httpRequest("POST", url, jsonData)
    
    if response then
        print("✅ Зарегистрирован!")
        return true
    else
        print("❌ Ошибка регистрации")
        return false
    end
end

local function getServerPlayers()
    local url = SERVER_URL .. "/api/players"
    local response = httpRequest("GET", url)
    
    if response then
        local data = HttpService:JSONDecode(response)
        if data and data.players then
            return data.players
        end
    end
    return {}
end

