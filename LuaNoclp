local function toggleFollowPlayer(playerObj)
    followActive = not followActive

    if followActive then
        if freeCameraActive then
            toggleFreeCamera()
        end
        if spectateActive then
            toggleSpectate()
        end

        if not playerObj or not playerObj.Character then
            followActive = false
            return
        end

        local target = playerObj.Character

        followConnection = RunService.Heartbeat:Connect(function()
            if target and target.PrimaryPart then
                Camera.CameraSubject = target.PrimaryPart
                Camera.CameraType = Enum.CameraType.Custom
            else
                if followConnection then
                    followConnection:Disconnect()
                    followConnection = nil
                end
                followActive = false
                Camera.CameraType = Enum.CameraType.Custom
                Camera.CameraSubject = player.Character
                updateMenuPopup(selectedPlayer)
            end
        end)
    else
        if followConnection then
            followConnection:Disconnect()
            followConnection = nil
        end
        Camera.CameraType = Enum.CameraType.Custom
        Camera.CameraSubject = player.Character
        updateMenuPopup(selectedPlayer)
    end
end

local function toggleFreeCamera()
    freeCameraActive = not freeCameraActive

    if freeCameraActive then
        if spectateActive then
            toggleSpectate()
        end
        if followActive then
            toggleFollowPlayer(selectedPlayer)
        end

        freezePlayer()

        local targetPos = Camera.CFrame.Position
        if selectedPlayer and selectedPlayer.Character and selectedPlayer.Character.PrimaryPart then
            targetPos = selectedPlayer.Character.PrimaryPart.Position
            Camera.CFrame = CFrame.new(targetPos + Vector3.new(0, 5, 10), targetPos)
        end

        Camera.CameraType = Enum.CameraType.Scriptable

        local speed = 50
        local shiftSpeed = 200

        freeCameraConnection = RunService.RenderStepped:Connect(function()
            local char = player.Character
            if char and char.PrimaryPart and playerFrozen then
                char.PrimaryPart.CFrame = playerOriginalCFrame
            end

            local moveVector = Vector3.new(0, 0, 0)
            local forward = Camera.CFrame.LookVector
            local right = Camera.CFrame.RightVector
            local up = Camera.CFrame.UpVector

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveVector = moveVector + forward
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveVector = moveVector - forward
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveVector = moveVector - right
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveVector = moveVector + right
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
                moveVector = moveVector - up
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then
                moveVector = moveVector + up
            end

            if moveVector.Magnitude > 0 then
                local currentSpeed = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and shiftSpeed or speed
                Camera.CFrame = Camera.CFrame + (moveVector.Unit * currentSpeed * RunService.RenderStepped:Wait())
            end
        end)

        local mouseInput
        mouseInput = UserInputService.InputChanged:Connect(function(input, processed)
            if processed then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Delta
                if delta.Magnitude > 0 then
                    local sensitivity = 0.005
                    local newCFrame = Camera.CFrame * CFrame.Angles(0, -delta.X * sensitivity, 0)
                    newCFrame = newCFrame * CFrame.Angles(-delta.Y * sensitivity, 0, 0)
                    Camera.CFrame = newCFrame
                end
            end
        end)

        freeCameraConnection = {freeCameraConnection, mouseInput}

    else
        if freeCameraConnection then
            if type(freeCameraConnection) == "table" then
                for _, conn in ipairs(freeCameraConnection) do
                    conn:Disconnect()
                end
            else
                freeCameraConnection:Disconnect()
            end
            freeCameraConnection = nil
        end
        unfreezePlayer()
        Camera.CameraType = Enum.CameraType.Custom
        Camera.CameraSubject = player.Character
    end
    updateMenuPopup(selectedPlayer)
end

