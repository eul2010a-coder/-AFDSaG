local RunService = game:GetService("RunService")

local Camera = nil

-- Ждём появления CurrentCamera
repeat
    Camera = workspace:FindFirstChild("CurrentCamera")
    task.wait(0.1)
until Camera

print("Camera найдена!")

local function ForceNoclip()
    Camera.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
    
    -- Усиленный хук
    local mt = getrawmetatable(Camera)
    setreadonly(mt, false)
    
    local oldNewIndex = mt.__newindex
    mt.__newindex = newcclosure(function(self, key, value)
        if self == Camera and key == "DevCameraOcclusionMode" then
            return oldNewIndex(self, key, Enum.DevCameraOcclusionMode.Invisicam)
        end
        return oldNewIndex(self, key, value)
    end)
    setreadonly(mt, true)
    
    -- Удаляем все Popper'ы
    for _, v in pairs(Camera:GetDescendants()) do
        if v.Name:lower():find("popper") or v.Name:find("Occlusion") then
            pcall(function() v:Destroy() end)
        end
    end
end

-- Запускаем
ForceNoclip()

-- Максимально агрессивная поддержка
RunService.RenderStepped:Connect(ForceNoclip)
RunService.Heartbeat:Connect(ForceNoclip)
RunService.Stepped:Connect(ForceNoclip)

print("✅ Камера Noclip должна работать (усиленная)")
