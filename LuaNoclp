end)

MinimizeButton.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    local targetSize = isMinimized and UDim2.new(0, 900, 0, 65) or UDim2.new(0, 900, 0, 600)
    local targetPos = isMinimized and UDim2.new(0.5, -450, 0.5, -32.5) or UDim2.new(0.5, -450, 0.5, -300)

    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = targetSize,
        Position = targetPos
    })
    tween:Play()
end)

