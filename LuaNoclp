    local function updateMinimap()
        for _, child in pairs(minimap:GetChildren()) do
            if child:IsA("Frame") and child.Name == "PlayerDot" then
                child:Destroy()
            end
        end

        local allPlayers = Players:GetPlayers()
        local playerPos = player.Character and player.Character.PrimaryPart and player.Character.PrimaryPart.Position or Vector3.new(0, 0, 0)

        local mapCenter = playerPos
        local mapScale = 50

        for _, plr in ipairs(allPlayers) do
            if plr.Character and plr.Character.PrimaryPart then
                local pos = plr.Character.PrimaryPart.Position
                local offset = pos - mapCenter

                local x = offset.X / mapScale
                local z = offset.Z / mapScale

                if math.abs(x) <= 3.5 and math.abs(z) <= 3.5 then
                    local dot = Instance.new("Frame")
                    dot.Parent = minimap
                    dot.Name = "PlayerDot"
                    dot.Size = UDim2.new(0, 8, 0, 8)
                    dot.Position = UDim2.new(0.5, x * 50, 0.5, z * 50)
                    dot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                    dot.BorderSizePixel = 0
                    dot.AnchorPoint = Vector2.new(0.5, 0.5)

                    if plr == player then
                        dot.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                        dot.Size = UDim2.new(0, 10, 0, 10)
                    elseif selectedPlayer and plr == selectedPlayer then
                        dot.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
                        dot.Size = UDim2.new(0, 12, 0, 12)
                        local glow = Instance.new("Frame")
                        glow.Parent = dot
                        glow.Size = UDim2.new(1, 8, 1, 8)
                        glow.Position = UDim2.new(0.5, -4, 0.5, -4)
                        glow.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
                        glow.BackgroundTransparency = 0.7
                        glow.BorderSizePixel = 0
                        glow.AnchorPoint = Vector2.new(0.5, 0.5)
                    end
                end
            end
        end
    end

    updateMinimap()

    local updateConnection
    updateConnection = RunService.Heartbeat:Connect(function()
        if MapFrame.Visible then
            updateMinimap()
        end
    end)

    MapFrame.Destroying:Connect(function()
        if updateConnection then
            updateConnection:Disconnect()
        end
    end)
end

